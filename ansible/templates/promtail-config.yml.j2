server:
  http_listen_port: 9080
  grpc_listen_port: 0

positions:
  filename: /tmp/positions.yaml

clients:
  - url: http://{{ monitoring_private_ip }}:3100/loki/api/v1/push

scrape_configs:
- job_name: system
  static_configs:
  - targets:
      - localhost
    labels:
      job: varlogs
      host: app-node
      __path__: /var/log/syslog

- job_name: nginx
  static_configs:
  - targets:
      - localhost
    labels:
      job: nginx
      host: app-node
      __path__: /var/log/nginx/*.log