groups:
  - name: node-alerts
    rules:
      - alert: HighCPUUsage
        expr: 100 - (avg by(instance)(rate(node_cpu_seconds_total{mode="idle"}[1m])) * 100) > 85
        for: 1m
        labels:
          severity: warning
        annotations:
          summary: "CPU usage is above 85% on {{ "{{ $labels.instance }}" }}"